runtime: python39
entrypoint: gunicorn -b :$PORT main:app


//main.py:
from flask import Flask, render_template
app = Flask(__name__)
@app.route('/')
def home():
    return render_template('index.html', title="Home Page")
if __name__ == '__main__':
    app.run(host='127.0.0.1', port=8080, debug=True)

